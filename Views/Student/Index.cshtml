@model List<StudentTaskManager.Models.Student>

<h2>Students List</h2>
<a href="/Student/Create">+ Add Student</a>
<table border="1">
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Email</th>
    </tr>
    @foreach (var s in Model)
    {
        <tr>
            <td>@s.Id</td>
            <td>@s.Name</td>
            <td>@s.Email</td>
        </tr>
    }
</table>