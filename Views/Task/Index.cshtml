@model List<StudentTaskManager.Models.TaskItem>

<h2>Tasks List</h2>
<a href="/Task/Create">+ Add Task</a>
<br />
<br />

<table border="1">
    <tr>
        <th>ID</th>
        <th>Title</th>
        <th>Description</th>
        <th>Status</th>
        <th>Action</th>
    </tr>

    @foreach (var t in Model)
    {
        <tr>
            <td>@t.Id</td>
            <td>@t.Title</td>
            <td>@t.Description</td>
            <td>@(t.IsCompleted ? "Done" : "Pending")</td>
            <td>
                @if (!t.IsCompleted)
                {
                    <a href="/Task/Complete/@t.Id">Complete</a>
                }
            </td>
        </tr>
    }
</table>